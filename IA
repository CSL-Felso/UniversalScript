local somMusica = Instance.new("Sound")
somMusica.Name = "MusicaIA_Global"
somMusica.Volume = 1
somMusica.Looped = true
somMusica.Parent = SS -- Definido após a criação conforme solicitado

local function playMusic(id)
    somMusica:Stop()
    somMusica.SoundId = "" 
    somMusica.SoundId = id
    if not somMusica.IsLoaded then
        somMusica.Loaded:Wait()
    end
    somMusica:Play()
    TestService:Message("[IA LOG] Tocando áudio: " .. id)
end

