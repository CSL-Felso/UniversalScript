-- =====================================================================
-- ⬛ 1. CRIAÇÃO DO CORPO (BOT)
-- =====================================================================
local function createDrone()
    local drone = Instance.new("Part", workspace)
    drone.Name = "IA_Assistente"
    drone.Size = Vector3.new(2, 2, 2)
    drone.Color = Color3.new(0, 0, 0)
    drone.Material = Enum.Material.Neon
    drone.CanCollide = false
    drone.Position = Player.Character.HumanoidRootPart.Position + Vector3.new(0, 10, 0)
    
    local bp = Instance.new("BodyPosition", drone)
    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    
    local bg = Instance.new("BodyGyro", drone)
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    
    local prompt = Instance.new("ProximityPrompt", drone)
    prompt.ActionText = "Falar com IA"
    prompt.ObjectText = "Cubo"
    prompt.RequiresLineOfSight = false 

    local emitter = Instance.new("ParticleEmitter", drone)
    emitter.Texture = "rbxassetid://1179108573"
    emitter.Color = ColorSequence.new(Color3.fromRGB(170, 0, 255))
    emitter.Rate = 20
    
    return drone, bp, bg, prompt
end

local bot, bodyPos, bodyGyro, proximityPrompt = createDrone()

-- =====================================================================
-- 🧠 2. MENTE E EXECUÇÃO
-- =====================================================================
local function executarResposta(resposta)
    if not resposta then return end
    
    -- Comando Luz: {luz: true, #hex, int}
    local est, hx, int = string.match(resposta, "{luz:%s*(%a+),%s*(#%x+),%s*(%d+)}")
    if est and hx and int then
        local cor = hexToColor3(hx)
        bot.Color = (est == "true") and cor or Color3.new(0, 0, 0)
        local l = bot:FindFirstChild("LuzIA") or Instance.new("PointLight", bot)
        l.Name = "LuzIA"
        l.Enabled = (est == "true")
        l.Color = cor
        l.Brightness = tonumber(int) or 5
        l.Range = 15
    end

    -- Comando Música
    local m = string.match(resposta, "{music:%s*(.-)}")
    if m and musicasTabela[string.lower(m)] then
        playMusic(musicasTabela[string.lower(m)])
    end

    -- Gateway de Proximidade
    if string.find(resposta, "{Getway: Proximity}") then
        gatewayAtivo = true
        alvoVoo = nil
        TestService:Message("[IA LOG] Sentinela ativo.")
    end

    -- Movimento
    if string.find(resposta, "{anda: \"User\"}") then 
        alvoVoo = Player 
        gatewayAtivo = false
    elseif string.find(resposta, "{stop}") then 
        alvoVoo = nil 
    end
    
    local textoLimpo = string.gsub(resposta, "{.-}", "")
    ChatService:Chat(bot, textoLimpo, Enum.ChatColor.White)
    
    StarterGui:SetCore("SendNotification", {
        Title = "IA Assistente",
        Text = textoLimpo,
        Duration = 5
    })
end

local function pensar(pergunta)
    local promptPersonalizado = PROMPT_SISTEMA:gsub("{NOME_JOGO}", nomeDoJogoAtual):gsub("{NOME_PLAYER}", Player.Name)
    local historicoTexto = table.concat(memoriaContexto, "\n")
    
    local url = "https://text.pollinations.ai/" .. HttpService:UrlEncode(historicoTexto .. "\nPergunta: " .. pergunta) .. "?system=" .. HttpService:UrlEncode(promptPersonalizado)
    
    local sucesso, res = pcall(function() return requestFunc({Url = url, Method = "GET"}) end)
    if sucesso and res.Success then
        local r = res.Body
        table.insert(memoriaContexto, "User: " .. pergunta)
        table.insert(memoriaContexto, "IA: " .. r)
        if #memoriaContexto > LIMITE_MEMORIA then table.remove(memoriaContexto, 1) end
        return r
    end
    return "Erro de conexão."
end

