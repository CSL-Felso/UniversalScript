proximityPrompt.Triggered:Connect(function()
    local playerGui = Player:WaitForChild("PlayerGui")
    local screenGui = Instance.new("ScreenGui", playerGui)
    local textBox = Instance.new("TextBox", screenGui)
    textBox.Size = UDim2.new(0, 400, 0, 60)
    textBox.Position = UDim2.new(0.5, -200, 0.4, 0)
    textBox.BackgroundColor3 = Color3.new(0, 0, 0)
    textBox.TextColor3 = Color3.new(1, 1, 1)
    textBox:CaptureFocus()

    textBox.FocusLost:Connect(function(enter)
        local txt = textBox.Text
        screenGui:Destroy()
        if enter and txt ~= "" then
            task.spawn(function() executarResposta(pensar(txt)) end)
        end
    end)
end)

RunService.Heartbeat:Connect(function()
    if alvoVoo and alvoVoo.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = alvoVoo.Character.HumanoidRootPart
        local t = tick()
        bodyPos.Position = hrp.Position + Vector3.new(math.sin(t*1.5)*3, 4 + math.sin(t*3)*0.5, math.cos(t*1.5)*3)
        bodyGyro.CFrame = CFrame.new(bot.Position, hrp.Position)
    end
    
    if gatewayAtivo then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if (p.Character.HumanoidRootPart.Position - bot.Position).Magnitude < 5 then
                    gatewayAtivo = false
                    alvoVoo = Player
                    executarResposta("Alerta! Detectei " .. p.Name .. " se aproximando. Voltando ao mestre.")
                    break
                end
            end
        end
    end
end)

